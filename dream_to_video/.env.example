# Dream-to-Video 环境变量配置
# 复制此文件为 .env 并修改值

# ====== API Key（四选一）======

# Claude (Anthropic) — 默认
# 获取方式：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI
# 获取方式：https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxx

# OpenRouter（聚合平台，可使用各种模型）
# 获取方式：https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-xxxxx

# Google Gemini
# 获取方式：https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIxxxxx

# ====== 可选 ======

# 管理员 Token（用于访问 /admin 接口，请设置一个随机字符串）
ADMIN_TOKEN=change-this-to-a-random-string

# Claude 模型（默认 claude-sonnet-4-20250514，可改为其他模型）
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 浏览器是否无头模式（服务器上设为 true）
HEADLESS=true

# 视频保留天数（超过此天数的视频自动清理）
VIDEO_RETENTION_DAYS=7

# 参考图目录（可选，不需要参考图功能可忽略）
# REFERENCE_IMAGE_DIR=/app/reference_images

# 数据目录（SQLite 数据库存放位置）
# DATA_DIR=/app/data
